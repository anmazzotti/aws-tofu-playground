# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is gitignored and must never be committed.

region = "eu-west-2"
owner  = "yourname"
owner_email            = "you@example.com"
pangolin_server_secret = "REPLACE_WITH_A_STRONG_RANDOM_SECRET"

# SSH access — set to your public IP as a /32 CIDR to allow SSH, or leave empty to disable it.
# Key-based auth only; passwords are always disabled by pangolin_init.sh regardless.
key_name          = ""
ssh_allowed_cidrs = []
# ssh_allowed_cidrs = ["YOUR_PUBLIC_IP/32"]

# Custom domain (optional) — leave empty to use the automatic sslip.io domain.
# When set, two Route53 A records are created: one for custom_domain and a wildcard
# for the parent zone. Both variables must be set together.
# The AWS credentials must have route53:ChangeResourceRecordSets and route53:GetChange.
# hosted_zone_id = "Z1PA6795UKMFR9"
# custom_domain  = "pangolin.example.com"
